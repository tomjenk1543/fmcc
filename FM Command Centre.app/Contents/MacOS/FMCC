#!/bin/bash
# FMCC app-mode launcher.
#
# Opens FM_Command_Centre.html in a plain, tab-free browser window (using
# Chrome's/Edge's own --app mode) instead of a normal tab, so it looks and
# feels like a standalone app. This doesn't run its own browser engine, so
# it needs Chrome, Edge, or Brave already installed - if none are found, it
# just opens the file in whatever the default browser is instead.

HTML_PATH="$HOME/Documents/FMCC/FM_Command_Centre.html"

if [ ! -f "$HTML_PATH" ]; then
    osascript -e 'display alert "FMCC not found" message "Expected FM_Command_Centre.html at ~/Documents/FMCC/. Move this launcher into that folder, or reinstall with setup.py."'
    exit 1
fi

for BROWSER in \
    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
    "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge" \
    "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"
do
    if [ -x "$BROWSER" ]; then
        "$BROWSER" --app="file://$HTML_PATH" >/dev/null 2>&1 &
        exit 0
    fi
done

# Fallback: no app-capable browser installed, just open normally.
open "$HTML_PATH"
